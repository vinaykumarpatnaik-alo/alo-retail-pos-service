{
  "name": "alo-retail-pos-service",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "build": "bun run --cwd apps/frontend build && bun run --cwd apps/middleware build && bun run --cwd workers/employee-order-events build",
    "dev": "bun run shopify app dev --reset",
    "dev:frontend": "bun run --cwd apps/frontend dev",
    "dev:middleware": "bun run --cwd apps/middleware dev",
    "typecheck": "bun run --cwd apps/frontend typecheck && bun run --cwd apps/middleware typecheck && bun run --cwd packages/pos-domain typecheck && bun run --cwd packages/shopify-auth typecheck && bun run --cwd workers/employee-order-events typecheck",
    "test": "bun test",
    "shopify": "shopify",
    "shopify:config": "bun scripts/render-shopify-config.mjs",
    "migrate:config": "bun scripts/migrate-retail-pos-config.mjs",
    "dev-extension": "bun run shopify app dev --reset",
    "generate": "bun run shopify app generate",
    "deploy": "bun run shopify:config && bun run shopify app deploy --config shopify.app.generated.toml --no-release"
  },
  "dependencies": {
    "@remote-ui/async-subscription": "^2.1.17",
    "@shopify/ui-extensions": "2025.7.3",
    "@shopify/ui-extensions-react": "2025.7.3",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.7",
    "google-libphonenumber": "^3.2.44",
    "jsonwebtoken": "^9.0.1",
    "lodash.throttle": "^4.1.1",
    "node-fetch": "^3.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-reconciler": "^0.29.2"
  },
  "devDependencies": {
    "@shopify/cli": "^3.84.2",
    "@types/bun": "^1.3.5",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "@types/react": "17.0.30"
  }
}
